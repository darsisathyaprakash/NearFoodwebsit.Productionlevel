# NearFood Environment Variables
# Copy this to .env and fill with your actual values

# ─── Application Configuration ─────────────────────────────
# Base URL for the application (required for metadata/social images)
NEXT_PUBLIC_BASE_URL=https://your-domain.com

# ─── InsForge Configuration ───────────────────────────
# Get these values from your InsForge dashboard: https://insforge.dev

# Your InsForge backend URL (required for authentication)
NEXT_PUBLIC_INSFORGE_BASE_URL=https://your-project.us-west.insforge.app

# Anonymous key (required for client-side database/storage operations)
NEXT_PUBLIC_INSFORGE_ANON_KEY=your_anon_key_here

# Admin/Service Key for migrations and backend operations (server-side only)
INSFORGE_API_KEY=your_api_key_here

# ─── Stripe Configuration ─────────────────────────────
# Get your keys from https://dashboard.stripe.com/apikeys
# Leave as dummy values for test mode — the app runs in dummy payment mode
STRIPE_SECRET_KEY=sk_test_dummy
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_dummy
